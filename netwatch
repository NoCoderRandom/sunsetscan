#!/usr/bin/env bash
#
# Compatibility launcher for the former NetWatch command.

set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
    SOURCE="$( readlink "$SOURCE" )"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"

echo "NOTICE: NetWatch has been renamed to SunsetScan. Use './sunsetscan' going forward." >&2
exec "$SCRIPT_DIR/sunsetscan" "$@"
