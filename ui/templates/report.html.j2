<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NetWatch Security Report — {{ metadata.network }}</title>
<style>
  /* ===== RESET & BASE ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 15px; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
    line-height: 1.6; color: #1a1a2e; background: #f0f2f5;
  }
  a { color: #2563eb; text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ===== LAYOUT ===== */
  .page { max-width: 1300px; margin: 0 auto; padding: 20px; }

  /* ===== HEADER ===== */
  .report-header {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 60%, #1e40af 100%);
    color: #fff; border-radius: 12px 12px 0 0; padding: 32px 40px 28px;
    display: flex; justify-content: space-between; align-items: flex-start;
    flex-wrap: wrap; gap: 16px;
  }
  .report-header h1 { font-size: 1.9rem; font-weight: 700; letter-spacing: -0.5px; }
  .report-header h1 span { color: #60a5fa; }
  .report-header .subtitle { font-size: 0.85rem; color: #94a3b8; margin-top: 4px; }
  .report-meta-right { text-align: right; font-size: 0.82rem; color: #94a3b8; }
  .report-meta-right strong { color: #e2e8f0; font-size: 0.95rem; display: block; }

  /* ===== METADATA BAR ===== */
  .meta-bar {
    background: #fff; border-left: 1px solid #e2e8f0; border-right: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0; padding: 16px 40px;
    display: flex; flex-wrap: wrap; gap: 24px; font-size: 0.82rem; color: #64748b;
  }
  .meta-item strong { display: block; color: #374151; font-size: 0.88rem; }

  /* ===== DASHBOARD ===== */
  .dashboard {
    background: #fff; border-radius: 0; border: 1px solid #e2e8f0;
    border-top: none; padding: 28px 40px;
  }
  .dashboard-title {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 1.2px;
    text-transform: uppercase; color: #6b7280; margin-bottom: 16px;
  }
  .severity-badges { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
  .badge {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 18px; border-radius: 8px;
    font-weight: 700; font-size: 1rem; min-width: 110px;
  }
  .badge .count { font-size: 1.6rem; line-height: 1; }
  .badge .label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.85; }
  .badge.critical { background: #fee2e2; color: #dc2626; }
  .badge.high     { background: #ffedd5; color: #ea580c; }
  .badge.medium   { background: #fef3c7; color: #d97706; }
  .badge.low      { background: #dbeafe; color: #2563eb; }
  .badge.info     { background: #f3f4f6; color: #6b7280; }

  /* Severity bar */
  .severity-bar { display: flex; height: 10px; border-radius: 5px; overflow: hidden; background: #e5e7eb; }
  .severity-bar .seg-critical { background: #dc2626; }
  .severity-bar .seg-high     { background: #ea580c; }
  .severity-bar .seg-medium   { background: #d97706; }
  .severity-bar .seg-low      { background: #2563eb; }
  .severity-bar .seg-info     { background: #9ca3af; }

  /* Stats row */
  .stats-row { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 20px; }
  .stat-card {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px;
    padding: 12px 20px; min-width: 120px;
  }
  .stat-card .stat-num { font-size: 1.5rem; font-weight: 700; color: #0f172a; }
  .stat-card .stat-lbl { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }

  /* ===== SECTION CARDS ===== */
  .section {
    background: #fff; border: 1px solid #e2e8f0; border-top: none;
    padding: 32px 40px;
  }
  .section:last-of-type { border-radius: 0 0 12px 12px; }
  .section-title {
    font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 20px;
    padding-bottom: 10px; border-bottom: 2px solid #e2e8f0;
    display: flex; align-items: center; gap: 8px;
  }

  /* ===== FINDINGS SUMMARY TABLE ===== */
  .findings-table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
  .findings-table th {
    background: #f8fafc; color: #374151; font-weight: 600; font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.5px; padding: 10px 14px;
    border-bottom: 2px solid #e2e8f0; text-align: left; white-space: nowrap;
  }
  .findings-table td { padding: 10px 14px; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
  .findings-table tr:hover td { background: #f8fafc; cursor: pointer; }
  .findings-table .sev-badge {
    display: inline-block; padding: 2px 9px; border-radius: 12px;
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; white-space: nowrap;
  }

  /* ===== HOST SECTIONS ===== */
  .host-section { margin-bottom: 24px; border: 1px solid #e2e8f0; border-radius: 10px; overflow: hidden; }
  .host-header {
    padding: 14px 20px; cursor: pointer; user-select: none;
    display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;
    background: #f8fafc; border-bottom: 1px solid #e2e8f0;
  }
  .host-header:hover { background: #f1f5f9; }
  .host-header .host-ip { font-size: 1rem; font-weight: 700; color: #0f172a; font-family: monospace; }
  .host-header .host-name { font-size: 0.82rem; color: #6b7280; margin-left: 8px; }
  .host-header .host-badges { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .host-header .toggle { color: #9ca3af; font-size: 1.2rem; transition: transform 0.2s; }
  .host-body { padding: 20px; }
  .host-meta { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 16px; font-size: 0.82rem; color: #374151; }
  .host-meta span { background: #f1f5f9; border-radius: 4px; padding: 3px 10px; }

  /* ===== FINDING CARDS ===== */
  .finding-card {
    border: 1px solid #e5e7eb; border-radius: 8px; margin-bottom: 14px; overflow: hidden;
  }
  .finding-card-header {
    display: flex; align-items: center; gap: 10px; padding: 11px 16px;
    border-bottom: 1px solid #e5e7eb; background: #fafafa;
  }
  .finding-card-body { padding: 14px 16px; font-size: 0.85rem; }
  .finding-title { font-weight: 600; color: #0f172a; font-size: 0.88rem; }
  .finding-port { font-size: 0.75rem; color: #6b7280; font-family: monospace; margin-left: auto; }

  .finding-section-lbl {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
    color: #9ca3af; margin-top: 10px; margin-bottom: 4px;
  }
  .finding-text { color: #374151; line-height: 1.55; }
  .finding-reco { color: #1e40af; line-height: 1.55; white-space: pre-line; }
  .finding-evidence {
    font-family: monospace; font-size: 0.78rem; color: #6b7280;
    background: #f8fafc; border-radius: 4px; padding: 6px 10px; margin-top: 8px;
    word-break: break-all; border: 1px solid #e5e7eb;
  }
  .cve-tag {
    display: inline-block; background: #fee2e2; color: #dc2626;
    border-radius: 4px; padding: 1px 7px; font-size: 0.72rem; font-weight: 600;
    font-family: monospace; margin-right: 4px; margin-top: 4px;
  }
  .cvss-tag {
    display: inline-block; border-radius: 4px; padding: 1px 7px;
    font-size: 0.72rem; font-weight: 700; margin-right: 4px;
  }

  /* ===== OPEN PORTS TABLE ===== */
  .ports-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-top: 16px; }
  .ports-table th {
    background: #f1f5f9; color: #374151; font-weight: 600; font-size: 0.73rem;
    text-transform: uppercase; letter-spacing: 0.5px; padding: 7px 12px;
    border-bottom: 1px solid #e2e8f0; text-align: left;
  }
  .ports-table td { padding: 7px 12px; border-bottom: 1px solid #f1f5f9; font-family: monospace; }
  .ports-table tr:last-child td { border-bottom: none; }

  /* ===== RECOMMENDATIONS ===== */
  .reco-list { counter-reset: reco-counter; list-style: none; }
  .reco-list li {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 12px 0; border-bottom: 1px solid #f1f5f9;
    font-size: 0.85rem;
  }
  .reco-list li:last-child { border-bottom: none; }
  .reco-num {
    counter-increment: reco-counter; min-width: 28px; height: 28px;
    background: #1e40af; color: #fff; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
  }
  .reco-item-host { font-family: monospace; color: #2563eb; font-size: 0.78rem; }

  /* ===== FOOTER ===== */
  .report-footer {
    text-align: center; padding: 20px; font-size: 0.78rem; color: #9ca3af;
    margin-top: 8px;
  }

  /* ===== SEVERITY COLOUR HELPERS ===== */
  .sev-critical { background: #fee2e2; color: #dc2626; }
  .sev-high     { background: #ffedd5; color: #ea580c; }
  .sev-medium   { background: #fef3c7; color: #d97706; }
  .sev-low      { background: #dbeafe; color: #2563eb; }
  .sev-info     { background: #f3f4f6; color: #6b7280; }

  .border-critical { border-left: 4px solid #dc2626 !important; }
  .border-high     { border-left: 4px solid #ea580c !important; }
  .border-medium   { border-left: 4px solid #d97706 !important; }
  .border-low      { border-left: 4px solid #2563eb !important; }
  .border-info     { border-left: 4px solid #9ca3af !important; }

  /* ===== EOL STATUS ===== */
  .eol-critical { color: #dc2626; font-weight: 600; }
  .eol-warning  { color: #d97706; font-weight: 600; }
  .eol-ok       { color: #059669; }
  .eol-unknown  { color: #9ca3af; }

  /* ===== EXECUTIVE SUMMARY ===== */
  .exec-summary {
    background: #fff; border: 1px solid #e2e8f0; border-top: none; padding: 28px 40px;
  }
  .exec-summary-title {
    font-size: 0.7rem; font-weight: 700; letter-spacing: 1.2px;
    text-transform: uppercase; color: #6b7280; margin-bottom: 12px;
  }
  .exec-summary-headline {
    font-size: 1.15rem; font-weight: 700; color: #0f172a; margin-bottom: 10px;
  }
  .exec-summary-body { font-size: 0.88rem; color: #374151; line-height: 1.7; }
  .exec-summary-body ul { margin: 8px 0 8px 24px; }
  .exec-summary-body li { margin-bottom: 4px; }

  /* ===== RISK SCORES ===== */
  .risk-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 16px; }
  .risk-card {
    display: flex; align-items: center; gap: 14px;
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 12px 18px; min-width: 200px;
  }
  .risk-score-circle {
    width: 52px; height: 52px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; font-weight: 800; color: #fff; flex-shrink: 0;
  }
  .risk-card .risk-ip { font-family: monospace; font-weight: 700; font-size: 0.9rem; color: #0f172a; }
  .risk-card .risk-label { font-size: 0.74rem; color: #6b7280; margin-top: 2px; }

  /* ===== CONFIDENCE BADGES ===== */
  .confidence-confirmed   { background: #d1fae5; color: #065f46; }
  .confidence-likely      { background: #dbeafe; color: #1e40af; }
  .confidence-suspected   { background: #fef3c7; color: #92400e; }
  .confidence-unconfirmed { background: #f3f4f6; color: #6b7280; }

  /* ===== DIFF SECTION ===== */
  .diff-section { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 16px 20px; margin-bottom: 16px; }
  .diff-added   { color: #059669; }
  .diff-removed { color: #dc2626; }
  .diff-changed { color: #d97706; }

  /* ===== FIXED ISSUES (GREEN) ===== */
  .fixed-section {
    background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;
    padding: 16px 20px; margin-top: 16px;
  }
  .fixed-title { color: #166534; font-weight: 700; font-size: 0.85rem; margin-bottom: 8px; }
  .fixed-item { color: #15803d; font-size: 0.82rem; padding: 2px 0; }

  /* ===== NETWORK TOPOLOGY ===== */
  .topology-grid { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 12px; }
  .topo-device {
    background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px;
    padding: 14px 18px; min-width: 180px; max-width: 240px;
    display: flex; flex-direction: column; gap: 4px;
  }
  .topo-device.gateway { border-color: #3b82f6; background: #eff6ff; }
  .topo-device-ip { font-family: monospace; font-weight: 700; font-size: 0.9rem; color: #0f172a; }
  .topo-device-name { font-size: 0.78rem; color: #6b7280; }
  .topo-device-ports { font-size: 0.72rem; color: #9ca3af; margin-top: 4px; }
  .topo-device-badge { font-size: 0.68rem; font-weight: 700; padding: 1px 6px; border-radius: 4px; width: fit-content; }
  .topo-device-id { font-size: 0.76rem; color: #1e40af; font-weight: 600; margin-top: 2px; }
  .topo-device-id-type { font-size: 0.7rem; color: #4b5563; font-style: italic; }

  /* ===== DEVICE IDENTITY ===== */
  .device-id-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
    border: 1px solid #93c5fd; border-radius: 8px;
    padding: 6px 14px; font-size: 0.82rem; color: #1e3a5f; font-weight: 600;
  }
  .device-id-badge .did-type { color: #3b82f6; font-weight: 700; }
  .device-id-badge .did-conf { font-size: 0.7rem; color: #6b7280; font-weight: 400; }

  /* ===== DEVICE INVENTORY TABLE ===== */
  .inventory-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .inventory-table th {
    background: #f1f5f9; color: #374151; font-weight: 700;
    text-align: left; padding: 10px 14px; border-bottom: 2px solid #e2e8f0;
    font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .inventory-table td { padding: 8px 14px; border-bottom: 1px solid #f1f5f9; }
  .inventory-table tr:hover { background: #f8fafc; }
  .inventory-conf {
    display: inline-block; min-width: 42px; text-align: center;
    padding: 1px 8px; border-radius: 10px; font-size: 0.72rem; font-weight: 600;
  }
  .conf-high { background: #dcfce7; color: #166534; }
  .conf-med  { background: #fef3c7; color: #92400e; }
  .conf-low  { background: #f3f4f6; color: #6b7280; }

  /* ===== POSTURE COLORS ===== */
  .posture-critical { color: #dc2626; }
  .posture-high     { color: #ea580c; }
  .posture-medium   { color: #d97706; }
  .posture-low      { color: #2563eb; }
  .posture-clean    { color: #059669; }

  /* ===== PRINT ===== */
  @media print {
    body { background: #fff; }
    .page { padding: 0; }
    .host-body { display: block !important; }
    .toggle { display: none; }
    .report-header { border-radius: 0; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- ====== HEADER ====== -->
  <div class="report-header">
    <div>
      <h1>Net<span>Watch</span> Security Report</h1>
      <div class="subtitle">Network Security Assessment Tool &bull; v{{ metadata.version }}</div>
    </div>
    <div class="report-meta-right">
      <strong>{{ metadata.network }}</strong>
      {{ metadata.scan_date }}<br>
      Profile: {{ metadata.profile }}
    </div>
  </div>

  <!-- ====== METADATA BAR ====== -->
  <div class="meta-bar">
    <div class="meta-item"><strong>{{ metadata.scan_date }}</strong>Scan Date</div>
    <div class="meta-item"><strong>{{ metadata.duration }}</strong>Duration</div>
    <div class="meta-item"><strong>{{ metadata.profile }}</strong>Scan Profile</div>
    <div class="meta-item"><strong>{{ metadata.hosts_up }} / {{ metadata.total_hosts }}</strong>Hosts Up</div>
    <div class="meta-item"><strong>{{ metadata.total_findings }}</strong>Total Findings</div>
    <div class="meta-item"><strong>v{{ metadata.version }}</strong>NetWatch Version</div>
  </div>

  <!-- ====== DASHBOARD ====== -->
  <div class="dashboard">
    <div class="dashboard-title">Severity Dashboard</div>

    <div class="severity-badges">
      <div class="badge critical">
        <div><div class="count">{{ counts.CRITICAL }}</div><div class="label">Critical</div></div>
      </div>
      <div class="badge high">
        <div><div class="count">{{ counts.HIGH }}</div><div class="label">High</div></div>
      </div>
      <div class="badge medium">
        <div><div class="count">{{ counts.MEDIUM }}</div><div class="label">Medium</div></div>
      </div>
      <div class="badge low">
        <div><div class="count">{{ counts.LOW }}</div><div class="label">Low</div></div>
      </div>
      <div class="badge info">
        <div><div class="count">{{ counts.INFO }}</div><div class="label">Info</div></div>
      </div>
    </div>

    {% set total_findings = counts.CRITICAL + counts.HIGH + counts.MEDIUM + counts.LOW + counts.INFO %}
    {% if total_findings > 0 %}
    <div class="severity-bar">
      {% if counts.CRITICAL > 0 %}<div class="seg-critical" style="width:{{ (counts.CRITICAL / total_findings * 100)|round(1) }}%"></div>{% endif %}
      {% if counts.HIGH > 0 %}    <div class="seg-high"     style="width:{{ (counts.HIGH     / total_findings * 100)|round(1) }}%"></div>{% endif %}
      {% if counts.MEDIUM > 0 %}  <div class="seg-medium"   style="width:{{ (counts.MEDIUM   / total_findings * 100)|round(1) }}%"></div>{% endif %}
      {% if counts.LOW > 0 %}     <div class="seg-low"      style="width:{{ (counts.LOW      / total_findings * 100)|round(1) }}%"></div>{% endif %}
      {% if counts.INFO > 0 %}    <div class="seg-info"     style="width:{{ (counts.INFO     / total_findings * 100)|round(1) }}%"></div>{% endif %}
    </div>
    {% endif %}

    <div class="stats-row">
      <div class="stat-card"><div class="stat-num">{{ metadata.total_hosts }}</div><div class="stat-lbl">Hosts Scanned</div></div>
      <div class="stat-card"><div class="stat-num">{{ metadata.hosts_up }}</div><div class="stat-lbl">Hosts Online</div></div>
      <div class="stat-card"><div class="stat-num">{{ metadata.total_open_ports }}</div><div class="stat-lbl">Open Ports</div></div>
      <div class="stat-card"><div class="stat-num">{{ metadata.total_findings }}</div><div class="stat-lbl">Total Findings</div></div>
    </div>
  </div>

  <!-- ====== EXECUTIVE SUMMARY ====== -->
  <div class="exec-summary">
    <div class="exec-summary-title">&#128196; Executive Summary</div>
    {% if executive_summary %}
    <div class="exec-summary-headline {% if executive_summary.posture %}posture-{{ executive_summary.posture }}{% endif %}">
      {{ executive_summary.headline }}
    </div>
    <div class="exec-summary-body">
      <p>{{ executive_summary.overview }}</p>
      {% if executive_summary.top_issues %}
      <ul>
        {% for issue in executive_summary.top_issues %}
        <li>{{ issue }}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if executive_summary.recommendation %}
      <p style="margin-top:8px;"><strong>Recommended next step:</strong> {{ executive_summary.recommendation }}</p>
      {% endif %}
    </div>

    {% if executive_summary.fixed_count and executive_summary.fixed_count > 0 %}
    <div class="fixed-section">
      <div class="fixed-title">&#10003; {{ executive_summary.fixed_count }} issue(s) resolved since last scan</div>
      {% if scan_diff and scan_diff.resolved_findings %}
        {% for finding in scan_diff.resolved_findings[:5] %}
        <div class="fixed-item">&#10003; {{ finding }}</div>
        {% endfor %}
        {% if scan_diff.resolved_findings|length > 5 %}
        <div class="fixed-item" style="color:#6b7280;">...and {{ scan_diff.resolved_findings|length - 5 }} more</div>
        {% endif %}
      {% endif %}
    </div>
    {% endif %}

    {% else %}
    <div class="exec-summary-body">
      <p>Scan complete. {{ metadata.hosts_up }} device(s) found online across {{ metadata.total_hosts }} scanned.
      {% if counts.CRITICAL > 0 %}
        <strong style="color:#dc2626;">{{ counts.CRITICAL }} critical issue(s) require immediate attention.</strong>
      {% elif counts.HIGH > 0 %}
        <strong style="color:#ea580c;">{{ counts.HIGH }} high-severity issue(s) were found.</strong>
      {% else %}
        No critical or high issues found.
      {% endif %}
      Total findings: {{ metadata.total_findings }}.</p>
    </div>
    {% endif %}

    {% if risk_scores %}
    <div style="margin-top:16px;">
      <div class="exec-summary-title" style="margin-bottom:8px;">&#127919; Device Risk Scores</div>
      <div class="risk-row">
        {% for ip, risk in risk_scores.items() | sort(attribute='1.score', reverse=True) %}
        <div class="risk-card">
          <div class="risk-score-circle" style="background:{{ risk.color }};">{{ risk.score }}</div>
          <div>
            <div class="risk-ip">{{ ip }}</div>
            <div class="risk-label">{{ risk.label }}</div>
            <div class="risk-label">{{ risk.finding_count }} finding(s)</div>
            {% if risk.top_findings %}
            <div class="risk-label" style="margin-top:2px;">
              Top: {% for f in risk.top_findings[:2] %}{{ f.title[:40] }}{% if not loop.last %}, {% endif %}{% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if scan_diff %}
    <div style="margin-top:16px;">
      <div class="exec-summary-title" style="margin-bottom:8px;">&#128260; Changes Since Last Scan</div>
      <div class="diff-section">
        {% for line in scan_diff.summary_lines() %}
        <div>{{ line }}</div>
        {% endfor %}
        <div style="font-size:0.75rem;color:#9ca3af;margin-top:6px;">
          Compared: {{ scan_diff.older_ts[:19] }} &#8594; {{ scan_diff.newer_ts[:19] }}
        </div>
      </div>
    </div>
    {% endif %}
  </div>

  <!-- ====== NETWORK TOPOLOGY ====== -->
  <div class="section">
    <div class="section-title">&#127760; Network Topology</div>
    <div class="topology-grid">
      {% for host_ip, host in hosts.items() %}
      {% if host.state == 'up' %}
      {% set is_gw = host_ip.endswith('.1') or host_ip.endswith('.254') %}
      <div class="topo-device {% if is_gw %}gateway{% endif %}">
        <div class="topo-device-ip">{{ host_ip }}</div>
        {% if device_identities and host_ip in device_identities %}
        {% set did = device_identities[host_ip] %}
        {% if did.device_type %}<div class="topo-device-id-type">{{ did.device_type }}</div>{% endif %}
        {% if did.vendor or did.model %}<div class="topo-device-id">{{ did.vendor }}{% if did.vendor and did.model %} {% endif %}{{ did.model }}</div>{% endif %}
        {% if did.version %}<div class="topo-device-name" style="font-family:monospace;">v{{ did.version }}</div>{% endif %}
        {% else %}
        {% if host.hostname %}<div class="topo-device-name">{{ host.hostname }}</div>{% endif %}
        {% if host.vendor %}<div class="topo-device-name">{{ host.vendor }}</div>{% endif %}
        {% if host.os_guess %}<div class="topo-device-name" style="font-style:italic;">{{ host.os_guess[:40] }}</div>{% endif %}
        {% endif %}
        {% if host.mac %}<div class="topo-device-name" style="font-family:monospace;">{{ host.mac }}</div>{% endif %}
        {% if is_gw %}
        <div class="topo-device-badge sev-info">Gateway</div>
        {% endif %}
        {% set hcounts = host_finding_counts.get(host_ip, {}) %}
        {% if hcounts.get('CRITICAL', 0) > 0 %}
          <div class="topo-device-badge sev-critical">{{ hcounts.CRITICAL }} Critical</div>
        {% elif hcounts.get('HIGH', 0) > 0 %}
          <div class="topo-device-badge sev-high">{{ hcounts.HIGH }} High</div>
        {% elif hcounts.get('MEDIUM', 0) > 0 %}
          <div class="topo-device-badge sev-medium">{{ hcounts.MEDIUM }} Medium</div>
        {% else %}
          <div class="topo-device-badge sev-info">No issues</div>
        {% endif %}
        {% if risk_scores and host_ip in risk_scores %}
        {% set risk = risk_scores[host_ip] %}
        <div class="topo-device-ports">Risk: {{ risk.score }}/100 — {{ risk.label }}</div>
        {% endif %}
        <div class="topo-device-ports">{{ host.ports | length }} open port(s): {% for pn in host.ports.keys() | sort | list %}{{ pn }}{% if not loop.last %}, {% endif %}{% endfor %}</div>
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- ====== DEVICE INVENTORY ====== -->
  {% if device_identities %}
  <div class="section">
    <div class="section-title">&#128270; Device Inventory</div>
    <div style="overflow-x:auto;">
      <table class="inventory-table">
        <thead>
          <tr>
            <th>IP Address</th>
            <th>Type</th>
            <th>Vendor</th>
            <th>Model</th>
            <th>Version</th>
            <th>Confidence</th>
            <th>Sources</th>
          </tr>
        </thead>
        <tbody>
          {% for ip, did in device_identities.items() | sort %}
          <tr onclick="scrollToHost('{{ ip }}')" style="cursor:pointer;" title="Click to go to host section">
            <td style="font-family:monospace; font-weight:600;">{{ ip }}</td>
            <td>{{ did.device_type or '—' }}</td>
            <td style="font-weight:600;">{{ did.vendor or '—' }}</td>
            <td>{{ did.model or '—' }}</td>
            <td style="font-family:monospace;">{{ did.version or '—' }}</td>
            <td>
              {% set conf_pct = (did.confidence * 100) | int %}
              <span class="inventory-conf {% if conf_pct >= 70 %}conf-high{% elif conf_pct >= 40 %}conf-med{% else %}conf-low{% endif %}">{{ conf_pct }}%</span>
            </td>
            <td style="font-size:0.72rem; color:#6b7280;">{{ did.sources | join(', ') }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  <!-- ====== FINDINGS SUMMARY TABLE ====== -->
  {% if all_findings %}
  <div class="section">
    <div class="section-title">&#9881; All Findings (sorted by severity)</div>
    <div style="overflow-x:auto;">
      <table class="findings-table" id="findings-table">
        <thead>
          <tr>
            <th>Severity</th>
            <th>Host</th>
            <th>Port</th>
            <th>Category</th>
            <th>Finding</th>
          </tr>
        </thead>
        <tbody>
          {% for f in all_findings %}
          <tr onclick="scrollToHost('{{ f.host }}')" title="Click to go to host section">
            <td><span class="sev-badge sev-{{ f.severity.lower() }}">{{ f.severity }}</span></td>
            <td style="font-family:monospace; white-space:nowrap;">{{ f.host }}</td>
            <td style="font-family:monospace; white-space:nowrap;">{{ f.port_display }}</td>
            <td style="white-space:nowrap; font-size:0.78rem; color:#6b7280;">{{ f.category }}</td>
            <td>{{ f.title }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}

  <!-- ====== HOST SECTIONS ====== -->
  <div class="section">
    <div class="section-title">&#128301; Host Details</div>

    {% for host_ip, host in hosts.items() %}
    {% set host_findings = findings_by_host.get(host_ip, []) %}
    {% set worst = worst_severity.get(host_ip, 'INFO') %}
    <div class="host-section" id="host-{{ host_ip|replace('.', '-') }}">

      <!-- Host header (clickable to collapse) -->
      <div class="host-header" onclick="toggleHost('{{ host_ip|replace('.', '-') }}')">
        <div>
          <span class="host-ip">{{ host_ip }}</span>
          {% if device_identities and host_ip in device_identities %}
          {% set did = device_identities[host_ip] %}
          <span class="host-name">&bull; {{ did.vendor }}{% if did.vendor and did.model %} {% endif %}{{ did.model }}{% if did.device_type %} ({{ did.device_type }}){% endif %}</span>
          {% else %}
          {% if host.hostname %}<span class="host-name">{{ host.hostname }}</span>{% endif %}
          {% if host.vendor %}<span class="host-name">&bull; {{ host.vendor }}</span>{% endif %}
          {% endif %}
        </div>
        <div class="host-badges">
          {% set hcounts = host_finding_counts.get(host_ip, {}) %}
          {% if hcounts.get('CRITICAL', 0) > 0 %}<span class="sev-badge sev-critical">{{ hcounts.CRITICAL }} Critical</span>{% endif %}
          {% if hcounts.get('HIGH', 0) > 0 %}    <span class="sev-badge sev-high">{{ hcounts.HIGH }} High</span>{% endif %}
          {% if hcounts.get('MEDIUM', 0) > 0 %}  <span class="sev-badge sev-medium">{{ hcounts.MEDIUM }} Medium</span>{% endif %}
          {% if hcounts.get('LOW', 0) > 0 %}     <span class="sev-badge sev-low">{{ hcounts.LOW }} Low</span>{% endif %}
          {% if not host_findings %}              <span class="sev-badge sev-info">No findings</span>{% endif %}
          {% if risk_scores and host_ip in risk_scores %}
          {% set risk = risk_scores[host_ip] %}
          <span style="background:{{ risk.color }}; color:#fff; border-radius:6px; padding:2px 9px; font-size:0.73rem; font-weight:700;">Risk {{ risk.score }}/100</span>
          {% endif %}
          <span class="toggle" id="toggle-{{ host_ip|replace('.', '-') }}">&#9660;</span>
        </div>
      </div>

      <!-- Host body -->
      <div class="host-body" id="body-{{ host_ip|replace('.', '-') }}">

        <!-- Host metadata -->
        <div class="host-meta">
          {% if host.mac %}<span>MAC: {{ host.mac }}</span>{% endif %}
          {% if host.vendor %}<span>Vendor: {{ host.vendor }}</span>{% endif %}
          {% if host.os_guess %}<span>OS: {{ host.os_guess }}{% if host.os_accuracy %} ({{ host.os_accuracy }}% confidence){% endif %}</span>{% endif %}
          <span>State: {{ host.state }}</span>
          <span>Open ports: {{ host.ports | length }}</span>
        </div>
        {% if device_identities and host_ip in device_identities %}
        {% set did = device_identities[host_ip] %}
        <div style="margin-bottom: 14px;">
          <div class="device-id-badge">
            {% if did.device_type %}<span class="did-type">{{ did.device_type }}</span> &mdash; {% endif %}
            {{ did.vendor }}{% if did.vendor and did.model %} {% endif %}{{ did.model }}
            {% if did.version %} v{{ did.version }}{% endif %}
            <span class="did-conf">{{ (did.confidence * 100) | int }}% confidence</span>
          </div>
        </div>
        {% endif %}

        <!-- Findings for this host -->
        {% if host_findings %}
        <div style="margin-bottom:16px;">
          {% for f in host_findings %}
          <div class="finding-card border-{{ f.severity.lower() }}">
            <div class="finding-card-header sev-{{ f.severity.lower() }}" style="opacity:0.95;">
              <span class="sev-badge sev-{{ f.severity.lower() }}">{{ f.severity }}</span>
              <span class="finding-title">{{ f.title }}</span>
              {% if f.confidence is defined and f.confidence != 'CONFIRMED' %}
              <span class="sev-badge confidence-{{ f.confidence.lower() }}" style="font-size:0.68rem;">{{ f.confidence }}</span>
              {% endif %}
              {% if f.port %}<span class="finding-port">{{ f.port_display }}</span>{% endif %}
            </div>
            <div class="finding-card-body">
              <div class="finding-section-lbl">What was found</div>
              <div class="finding-text">{{ f.description }}</div>

              <div class="finding-section-lbl" style="margin-top:12px;">What this means</div>
              <div class="finding-text">{{ f.explanation }}</div>

              <div class="finding-section-lbl" style="margin-top:12px;">What to do</div>
              <div class="finding-reco">{{ f.recommendation }}</div>

              {% if f.evidence %}
              <div class="finding-evidence">Evidence: {{ f.evidence }}</div>
              {% endif %}

              {% if f.cve_ids %}
              <div style="margin-top:8px;">
                {% for cve in f.cve_ids %}<span class="cve-tag">{{ cve }}</span>{% endfor %}
                {% if f.cvss_score is not none %}
                <span class="cvss-tag sev-{{ f.severity.lower() }}">CVSS {{ f.cvss_score }}</span>
                {% endif %}
              </div>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        </div>
        {% else %}
        <p style="color:#6b7280; font-size:0.85rem; margin-bottom:12px;">No significant findings for this host.</p>
        {% endif %}

        <!-- Open ports table -->
        {% if host.ports %}
        <div style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.8px; color:#9ca3af; margin-bottom:8px;">Open Ports</div>
        <div style="overflow-x:auto;">
          <table class="ports-table">
            <thead>
              <tr>
                <th>Port</th>
                <th>Protocol</th>
                <th>Service</th>
                <th>Version</th>
                <th>EOL Status</th>
              </tr>
            </thead>
            <tbody>
              {% for port_num, port in host.ports.items() | sort %}
              {% set eol = eol_data.get(host_ip, {}).get(port_num) %}
              <tr>
                <td>{{ port.port }}</td>
                <td>{{ port.protocol }}</td>
                <td>{{ port.service or '—' }}</td>
                <td>{{ port.version or '—' }}</td>
                <td>
                  {% if eol %}
                    {% if eol.level.value == 'CRITICAL' %}
                      <span class="eol-critical">EOL: {{ eol.eol_date.strftime('%Y-%m-%d') if eol.eol_date else 'reached' }}</span>
                    {% elif eol.level.value == 'WARNING' %}
                      <span class="eol-warning">Warning: {{ eol.days_remaining }}d remaining</span>
                    {% elif eol.level.value == 'OK' %}
                      <span class="eol-ok">Supported</span>
                    {% elif eol.level.value == 'N/A' %}
                      <span class="eol-unknown" title="{{ eol.message }}">N/A</span>
                    {% else %}
                      <span class="eol-unknown">Unknown</span>
                    {% endif %}
                  {% else %}
                    <span class="eol-unknown">—</span>
                  {% endif %}
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

      </div><!-- /host-body -->
    </div><!-- /host-section -->
    {% endfor %}
  </div>

  <!-- ====== RECOMMENDATIONS ====== -->
  {% set actionable = all_findings | selectattr('severity', 'in', ['CRITICAL','HIGH','MEDIUM']) | list %}
  {% if actionable %}
  <div class="section">
    <div class="section-title">&#9989; Recommended Actions (by priority)</div>
    <ul class="reco-list">
      {% for f in actionable %}
      <li>
        <div class="reco-num">{{ loop.index }}</div>
        <div>
          <div style="margin-bottom:4px;">
            <span class="sev-badge sev-{{ f.severity.lower() }}">{{ f.severity }}</span>
            &nbsp;<strong>{{ f.title }}</strong>
            &nbsp;<span class="reco-item-host">{{ f.host }}{% if f.port %}:{{ f.port }}{% endif %}</span>
          </div>
          <div class="finding-reco" style="color:#374151;">{{ f.recommendation }}</div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- ====== FOOTER ====== -->
  <div class="report-footer">
    Generated by <strong>NetWatch v{{ metadata.version }}</strong>
    &bull; {{ metadata.scan_date }}
    &bull; This report is for authorised use only.
    EOL data provided by endoflife.date &bull; CVE data from OSV.dev
  </div>

</div><!-- /page -->

<script>
  function toggleHost(id) {
    var body = document.getElementById('body-' + id);
    var toggle = document.getElementById('toggle-' + id);
    if (!body) return;
    if (body.style.display === 'none') {
      body.style.display = '';
      if (toggle) toggle.innerHTML = '&#9660;';
    } else {
      body.style.display = 'none';
      if (toggle) toggle.innerHTML = '&#9654;';
    }
  }

  function scrollToHost(ip) {
    var id = 'host-' + ip.replace(/\./g, '-');
    var el = document.getElementById(id);
    if (!el) return;
    // Expand if collapsed
    var body = document.getElementById('body-' + ip.replace(/\./g, '-'));
    if (body && body.style.display === 'none') toggleHost(ip.replace(/\./g, '-'));
    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Auto-collapse INFO-only hosts on load to reduce visual noise
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.host-section').forEach(function (section) {
      var badges = section.querySelectorAll('.sev-badge');
      var hasRisk = false;
      badges.forEach(function (b) {
        var t = b.textContent.trim().toLowerCase();
        if (t.includes('critical') || t.includes('high') || t.includes('medium')) hasRisk = true;
      });
      if (!hasRisk) {
        var id = section.id.replace('host-', '');
        var body = document.getElementById('body-' + id);
        var toggle = document.getElementById('toggle-' + id);
        if (body) body.style.display = 'none';
        if (toggle) toggle.innerHTML = '&#9654;';
      }
    });
  });
</script>
</body>
</html>
